# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Build / dist ───────────────────────────────────────────────
dist/
build/
*.egg-info/

# ── Test & coverage ────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Linters ────────────────────────────────────────────────────
.ruff_cache/

# ── Runtime outputs (generated by this skill) ─────────────────
# Hermes writes project params here; never commit real project data
params.json

# Generated chapter Markdown (Hermes output, not source)
# Use /chapters/ (anchored to root) so tests/fixtures/chapters/ is NOT ignored
/chapters/

# Exported Word reports
/exports/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Cursor IDE ────────────────────────────────────────────────
.cursor/

# ── Secrets / environment ─────────────────────────────────────
.env
.env.*
*.key
*.pem
